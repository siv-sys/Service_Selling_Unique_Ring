# Backend Environment Variables Template
# Copy this to .env.production and fill in your values

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=4001
NODE_ENV=production

# ============================================
# DATABASE CONFIGURATION (MySQL)
# ============================================
# Use a production MySQL service like:
# - AWS RDS
# - PlanetScale
# - Railway
# - Supabase
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-secure-password-here
DB_NAME=bondkeeper

# Connection Pool Settings
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT=60000

# ============================================
# JWT CONFIGURATION
# ============================================
# Generate a strong secret key (min 32 characters)
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
JWT_EXPIRES_IN=7d
JWT_ISSUER=ringos-platform

# ============================================
# REDIS CONFIGURATION (Optional)
# ============================================
# Use Redis for caching, sessions, real-time features
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_TTL=3600

# ============================================
# CORS CONFIGURATION
# ============================================
# Your frontend URL(s)
CLIENT_URL=http://localhost:5173
FRONTEND_PRODUCTION_URL=https://your-frontend.vercel.app

# ============================================
# API CONFIGURATION
# ============================================
API_BASE_URL=http://localhost:4001/api
API_VERSION=v1

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp

# ============================================
# EMAIL CONFIGURATION (Future)
# ============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=noreply@ringos.com
EMAIL_PASS=your-email-password
EMAIL_FROM=RingOS Platform <noreply@ringos.com>

# ============================================
# SMS CONFIGURATION (Future - Twilio)
# ============================================
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# ANALYTICS & MONITORING (Optional)
# ============================================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
LOG_LEVEL=info

# ============================================
# RATE LIMITING (Security)
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# SECURITY
# ============================================
BCRYPT_ROUNDS=10
SESSION_SECRET=another-secret-key-for-sessions

# ============================================
# APPLICATION SETTINGS
# ============================================
APP_NAME=RingOS Platform
APP_VERSION=2.0.0
SUPPORT_EMAIL=support@ringos.com

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_CACHE=false
ENABLE_RATE_LIMIT=true
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_REALTIME_FEATURES=false
